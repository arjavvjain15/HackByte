# ── Dependencies ──────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build output ──────────────────────────────────────────────
dist/
dist-ssr/
build/
out/

# ── Vite cache (pre-bundled deps — never commit these) ────────
**/.vite/
.vite/

# ── Environment variables ─────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
